# Copy to .env and fill in at least one LLM provider key.
JWT_SECRET=change-me-in-prod
DATABASE_URL=sqlite:///./gadgents.db

# LLM provider fallback order: OpenRouter (main, free daily quota) -> OpenAI
# (specific high-quality, free daily quota on Tier 2/3) -> Ollama (local, free).
LLM_PROVIDER_ORDER=openrouter,openai,ollama

OPENAI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
OLLAMA_BASE_URL=

CREDIT_PRICE_PER_USD=100
FREE_CREDITS_ON_SIGNUP=50
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

CORS_ORIGINS=http://localhost:5173

# OpenAI model ids (optional override; paste exact names from the OpenAI model page)
OPENAI_MODEL_SOL=gpt-5.6-sol
OPENAI_MODEL_TERRA=gpt-5.6-terra
OPENAI_MODEL_CODEX=gpt-5.1-codex
OPENAI_MODEL_LUNA=gpt-5.6-luna
OPENAI_MODEL_MINI=gpt-5.4-mini-2026-03-17
OPENAI_MODEL_NANO=gpt-5.4-nano-2026-03-17

# OpenRouter model ids (optional override; swap to limited-time free models without code edits)
OPENROUTER_MODEL_OPUS=anthropic/claude-opus-4.8
OPENROUTER_MODEL_SONNET5=anthropic/claude-sonnet-5
OPENROUTER_MODEL_SONNET46=anthropic/claude-sonnet-4.6
OPENROUTER_MODEL_KIMI=moonshotai/kimi-k2.6
OPENROUTER_MODEL_DS_PRO=deepseek/deepseek-v4-pro
OPENROUTER_MODEL_NEX=nex-agi/nex-n2-pro
OPENROUTER_MODEL_QWEN37=qwen/qwen3.7-plus
OPENROUTER_MODEL_QWEN36=qwen/qwen3.6-35b-a3b
OPENROUTER_MODEL_QWEN35=qwen/qwen3.5-plus-20260420
OPENROUTER_MODEL_GLM=z-ai/glm-5.2
OPENROUTER_MODEL_HY3=tencent/hy3
OPENROUTER_MODEL_NEMOTRON=nvidia/nemotron-3-super-120b-a12b
OPENROUTER_MODEL_MIMO=xiaomi/mimo-v2-pro
OPENROUTER_MODEL_HAIKU=anthropic/claude-haiku-4.5
OPENROUTER_MODEL_LLAMA33=meta-llama/llama-3.3-70b-instruct
OPENROUTER_MODEL_DS_FLASH=deepseek/deepseek-v4-flash
OPENROUTER_MODEL_DS_FLASH_FREE=deepseek/deepseek-v4-flash:free
OPENROUTER_MODEL_OWL=openrouter/owl-alpha

# Dev / preview mode. Set both to false to use every agent without login or credits
# (good for QA). Flip both to true before going live / enabling billing.
REQUIRE_LOGIN=true
ENABLE_PAYWALL=true

# Lead Finder agent: local Firecrawl (firecrawl-simple / firecrawl) for JS-rendered
# discovery + deep domain audit. Only used when a run sets use_firecrawl=true.
# Leave default to run the agent in DuckDuckGo + HTTP mode (no external service).
FIRECRAWL_BASE_URL=http://localhost:3002
FIRECRAWL_API_KEY=test-key-123
